# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Anthropic API key used by the extraction pipeline (Pillar A) and the assistant (Pillar C).
ANTHROPIC_API_KEY=

# Write-access gate (see plan.md §3).
#   false  -> local demo: every write action is available with no prompt (default)
#   true   -> shared use: upload / extract / approve require the shared password below
REQUIRE_PASSWORD=false
WRITE_PASSWORD=change-me-before-enabling

# Pinned extraction prompt version (file lives in prompts/<version>.md).
EXTRACTION_PROMPT_VERSION=extraction_v7

# Models.
EXTRACTION_MODEL=claude-opus-4-8
ASSISTANT_MODEL=claude-haiku-4-5-20251001

# Loose backstop (not a hard cap) on tokens an extraction call may spend
# across its whole code-execution tool loop. See prompts/CHANGELOG.md.
EXTRACTION_TASK_BUDGET_TOKENS=100000
